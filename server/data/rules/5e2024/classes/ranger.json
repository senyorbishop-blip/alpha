  "featureDefinitions": {
    "ranger-l1-1": {
      "summary": "Mark dangerous prey and study enemy patterns so your damage and tracking feel purposeful rather than generic.",
      "description": "Favored Enemy should make the ranger feel like a hunter with intent. It is about target pressure, tracking, and tactical focus instead of simply being a passive lore note.",
      "tags": [
        "combat",
        "tracking",
        "identity"
      ]
    },
    "ranger-l1-2": {
      "summary": "Your chosen weapons carry tactical mastery properties that make attacks feel more distinctive than simple swings.",
      "description": "Weapon Mastery is an attack-surface feature. It matters because it changes how the ranger approaches weapon turns and should be visible wherever weapon actions are shown.",
      "tags": [
        "martial",
        "combat",
        "weapons"
      ]
    },
    "ranger-l2-1": {
      "summary": "You become a stronger explorer and traveler so the ranger contributes clearly between fights as well as during them.",
      "description": "Deft Explorer is utility identity for ranger. It should help the class feel like a guide, scout, and endurance specialist instead of only a bow user with spells.",
      "tags": [
        "exploration",
        "utility",
        "identity"
      ]
    },
    "ranger-l2-2": {
      "summary": "Ranger spellcasting supports the hunt with movement, marking, control, and survival tools rather than replacing your martial core.",
      "description": "Ranger spells should feel like practical field magic: mobility, tracking, control, self-buffs, and the occasional decisive strike instead of full-caster breadth.",
      "tags": [
        "spellcasting",
        "martial",
        "primal"
      ]
    },
    "ranger-l2-3": {
      "summary": "Choose the combat style that defines how your ranger pressures the battlefield.",
      "description": "Fighting Style is a structural class choice. It should clearly influence whether the ranger reads as ranged pressure, defensive skirmisher, two-weapon attacker, or another martial angle.",
      "tags": [
        "build",
        "combat",
        "identity"
      ]
    },
    "ranger-l3-1": {
      "summary": "Your conclave determines how you hunt, survive, and shape your battlefield presence as the class progresses.",
      "description": "Ranger Conclave is the subclass gate for ranger. It should instantly tell the player whether this character is a stalker, companion master, focused slayer, fey wanderer, or another specialist hunter.",
      "tags": [
        "subclass",
        "identity",
        "hunt"
      ]
    },
    "ranger-l3-2": {
      "summary": "Your movement becomes more fluid, letting you cross the field and rough terrain like a practiced scout.",
      "description": "Roving is a quality-of-life mobility feature, but it matters constantly because it improves how the ranger approaches pursuit, kiting, and difficult approaches.",
      "tags": [
        "mobility",
        "exploration",
        "passive"
      ]
    },
    "ranger-l10-2": {
      "summary": "You can shake off fatigue and keep moving, reinforcing the ranger as a long-haul survivor.",
      "description": "Tireless is an endurance feature. It should matter on travel-heavy days, attrition-heavy adventuring, and any campaign where the ranger’s staying power matters as much as their aim.",
      "tags": [
        "survival",
        "rest",
        "identity"
      ]
    },
    "ranger-l14-2": {
      "section": "Bonus Actions",
      "type": "bonus action",
      "summary": "Slip from sight with primal subtlety so you can reposition, disengage attention, or open a cleaner line.",
      "description": "Nature’s Veil is a strong tactical button. It helps the ranger take control of line-of-sight and positioning, which is exactly where the class often wants to fight.",
      "tags": [
        "stealth",
        "mobility",
        "combat"
      ]
    },
    "ranger-l20-1": {
      "summary": "Your greatest hunts end with deadly certainty, turning focused pressure into a true capstone threat.",
      "description": "Foe Slayer is the ranger capstone identity and a true hunter payoff: when the quarry matters, the class becomes precise and deadly enough to finish the hunt with real certainty.",
      "tags": [
        "capstone",
        "combat",
        "hunt"
      ]
    }
  },

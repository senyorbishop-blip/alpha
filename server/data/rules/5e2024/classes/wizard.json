  "featureDefinitions": {
    "wizard-spellcasting": {
      "summary": "Maintain a spellbook, prepare arcane tools from it, and solve problems through the broadest magical list in the game.",
      "description": "Wizard spellcasting is about breadth, planning, and precision. You maintain a spellbook, prepare a subset of spells for the day, and then answer encounters with exactly the right arcane tool when you read the situation well.\n\nThe sheet should make this feel distinct from spontaneous casters: a wizard is rewarded for knowledge, preparation, and using the spellbook as a real resource.",
      "tags": [
        "spellcasting",
        "arcane",
        "control",
        "utility"
      ]
    },
    "wizard-arcane-recovery": {
      "summary": "Restore part of your spell economy during a short rest so the wizard can stay useful across a full adventuring day.",
      "description": "Arcane Recovery helps the wizard avoid spending all meaningful spell power in the first major encounter. It should be surfaced as a rest-phase decision that rewards smart slot management rather than panic casting.",
      "resourceName": "Arcane Recovery",
      "trackUses": true,
      "usage": "1 use available",
      "recovery": "You can use this once per day after finishing a Short Rest.",
      "tags": [
        "spellcasting",
        "resource",
        "recovery"
      ]
    },
    "wizard-scholar": {
      "summary": "Your training is not just magical talent — it is practiced, studied expertise in arcane knowledge and careful problem solving.",
      "description": "Scholar is the wizard identity reminder that knowledge matters. It should communicate that this class solves scenes through preparation, research, recall, and careful arcane understanding, not only damage output.",
      "tags": [
        "knowledge",
        "utility",
        "arcane"
      ]
    },
    "wizard-arcane-tradition-subclass": {
      "summary": "Your chosen school or specialty changes the shape of your wizardry and the kinds of magical advantages you build around.",
      "description": "Arcane Tradition is the subclass gate for wizard. This is where the class stops being a generic spellcaster and becomes an Abjurer, Diviner, Evoker, or Illusionist with a focused play pattern and a reason to approach encounters differently.",
      "tags": [
        "subclass",
        "spellcasting",
        "identity",
        "build"
      ]
    },
    "wizard-memorize-spell": {
      "summary": "Reconfigure part of your prepared toolkit more flexibly than most casters, keeping the wizard adaptable between problems.",
      "description": "Memorize Spell reinforces the wizard fantasy of careful preparation and mid-adventure adaptation. The point is not raw power; it is the ability to pivot when new information changes which spell will matter next.",
      "tags": [
        "spellcasting",
        "utility",
        "preparation"
      ]
    },
    "wizard-cantrip-formulas": {
      "summary": "Your basic magical routines become easier to swap and refine so your fallback toolkit stays useful.",
      "description": "Cantrip Formulas matters because cantrips are used constantly. This feature should feel like wizard flexibility scaled down to the at-will level: a small but meaningful quality-of-life advantage that makes daily preparation less rigid.",
      "tags": [
        "spellcasting",
        "cantrip",
        "flexibility"
      ]
    },
    "wizard-spell-mastery": {
      "summary": "Choose signature lower-level spells that become part of your permanent operating rhythm instead of your precious daily budget.",
      "description": "Spell Mastery is one of the clearest high-level wizard payoffs. It turns a couple of dependable spells into tools you can lean on repeatedly, freeing your main slots for more dramatic effects and making the class feel truly seasoned.",
      "tags": [
        "spellcasting",
        "mastery",
        "endgame"
      ]
    },
    "wizard-signature-spells": {
      "summary": "Your most iconic prepared spells become effortless enough that they define how this wizard approaches every serious adventuring day.",
      "description": "Signature Spells is the capstone-level expression of wizard mastery. By this point, the character has favorite spells that are woven so deeply into their routine that they feel almost reflexive, and the sheet should present that as a real class identity payoff.",
      "tags": [
        "spellcasting",
        "capstone",
        "identity",
        "endgame"
      ]
    }
  },

    "sorcerer-l5-1": {
      "section": "Bonus Actions",
      "type": "bonus action",
      "summary": "Steady yourself with a burst of restored vigor so your fragile caster chassis stays in the fight longer.",
      "description": "Sorcerous Vitality gives the class a self-stabilizing button. It matters because sorcerers often feel exposed once pressure reaches them, and this feature helps them recover tempo.",
      "tags": [
        "survival",
        "self-heal",
        "arcane"
      ],
      "resourceName": "Sorcerous Vitality",
      "trackUses": true,
      "usage": "Use once per long rest unless other features improve it.",
      "recovery": "Refreshes on a long rest."
    },
    "sorcerer-l7-1": {
      "summary": "Push your innate state to a more complete form so your signature magic feels fully online in major encounters.",
      "description": "Sorcery Incarnate is a dramatic identity spike. It should read like the sorcerer no longer merely has power, but actively becomes the vessel for it during a key fight.",
      "tags": [
        "signature",
        "arcane",
        "power-state"
      ],
      "section": "Bonus Actions",
      "type": "bonus action",
      "resourceName": "Sorcery Points",
      "trackUses": true,
      "usage": "Enter your sorcery incarnate state during a key fight.",
      "recovery": "Sorcery Point spenders refresh on a long rest."
    },
    "sorcerer-l18-1": {
      "summary": "Your mastery of raw magic reaches a rarefied peak where high-end casting feels effortless and overwhelming.",
      "description": "Arcane Apotheosis is the late-game sorcerer fantasy: raw magical force refined to the point that the class feels almost mythic in its command of personal power.",
      "tags": [
        "capstone-adjacent",
        "arcane",
        "signature"
      ],
      "section": "Class Features",
      "type": "passive"
    },
    "sorcerer-l20-1": {
      "summary": "Your apotheosis sharpens even further, turning your innate magic into something close to a living magical phenomenon.",
      "description": "Arcane Apotheosis (Improved) is the final expression of the sorcerer fantasy. It should feel like relentless magical presence rather than one more number bump.",
      "tags": [
        "capstone",
        "arcane",
        "mythic"
      ],
      "section": "Class Features",
      "type": "passive"
    },

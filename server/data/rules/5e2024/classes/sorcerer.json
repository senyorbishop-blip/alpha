    "sorcerer-l4-1": {
      "summary": "Improve your core ability scores or take a feat to shape your signature casting style.",
      "description": "This is a major build fork: increase Charisma/Constitution for cleaner spell output and durability, or take a feat that reinforces your sorcery game plan.",
      "tags": [
        "build",
        "progression"
      ]
    },
    "sorcerer-l4-2": {
      "summary": "Your at-will magic depth increases to five cantrips known.",
      "description": "Another cantrip widens your no-slot toolkit so the class keeps a personal magical identity even in low-slot fights.",
      "tags": [
        "spellcasting",
        "cantrip"
      ]
    },
    "sorcerer-l6-1": {
      "summary": "Your Sorcerous Origin advances with a defining subclass feature.",
      "description": "Level 6 is where your origin starts materially changing your turn decisions, not just your flavor text.",
      "tags": [
        "subclass",
        "progression",
        "identity"
      ]
    },
    "sorcerer-l8-1": {
      "summary": "Another Ability Score Improvement or feat sharpens your sorcerer game plan.",
      "description": "Use this to reinforce casting reliability, survivability, or a feat package that complements your Metamagic choices.",
      "tags": [
        "build",
        "progression"
      ]
    },
    "sorcerer-l9-1": {
      "summary": "You unlock 5th-level spells and a new power tier for encounter-defining casts.",
      "description": "This spell-tier jump should be obvious in both slot visibility and known-spell planning because it changes what fights you can solve directly.",
      "tags": [
        "spellcasting",
        "progression"
      ]
    },
    "sorcerer-l10-2": {
      "summary": "Your cantrip list expands again to six known cantrips.",
      "description": "This keeps your no-slot identity relevant while Sorcery Points and leveled spells are reserved for higher-pressure moments.",
      "tags": [
        "spellcasting",
        "cantrip"
      ]
    },
    "sorcerer-l11-1": {
      "summary": "You unlock 6th-level spells and access to high-impact arcane effects.",
      "description": "This progression point expands your upper-tier spell identity and should stand out in spell list management and slot planning.",
      "tags": [
        "spellcasting",
        "progression"
      ]
    },
    "sorcerer-l12-1": {
      "summary": "Another Ability Score Improvement or feat to refine your late-midgame build.",
      "description": "At this stage, optimize the stats or feats that best support your preferred Metamagic and spell selection patterns.",
      "tags": [
        "build",
        "progression"
      ]
    },
    "sorcerer-l13-1": {
      "summary": "You unlock 7th-level spells for stronger control, utility, and burst options.",
      "description": "Your spell ceiling rises again, so sheet and level-up surfaces should make the new tier immediately visible.",
      "tags": [
        "spellcasting",
        "progression"
      ]
    },
    "sorcerer-l14-1": {
      "summary": "Your Sorcerous Origin gains another subclass-defining feature.",
      "description": "This is a subclass identity spike where your origin should feel mechanically distinct in active play.",
      "tags": [
        "subclass",
        "progression",
        "identity"
      ]
    },
    "sorcerer-l15-1": {
      "summary": "You unlock 8th-level spells and another major spellcasting tier jump.",
      "description": "High-tier spell access should be reflected clearly in slot visibility, known spell planning, and combat expectations.",
      "tags": [
        "spellcasting",
        "progression"
      ]
    },
    "sorcerer-l15-2": {
      "summary": "Your Sorcerous Origin advances again with its high-level subclass feature.",
      "description": "This progression point should keep subclass identity visible in gameplay rather than leaving it as passive lore.",
      "tags": [
        "subclass",
        "progression",
        "identity"
      ]
    },
    "sorcerer-l16-1": {
      "summary": "Another Ability Score Improvement or feat strengthens your endgame casting profile.",
      "description": "Use this level to lock in your final core stat line or feat package before top-tier spell play.",
      "tags": [
        "build",
        "progression"
      ]
    },
    "sorcerer-l17-1": {
      "summary": "You unlock 9th-level spells, the highest tier of arcane casting.",
      "description": "This is the top spell-tier breakpoint and should be explicitly visible in slots, known spells, and action planning.",
      "tags": [
        "spellcasting",
        "progression",
        "capstone-adjacent"
      ]
    },
    "sorcerer-l19-1": {
      "summary": "Gain an Epic Boon as a late-game power reinforcement.",
      "description": "Epic Boons are endgame build spikes that further specialize your character beyond normal class scaling.",
      "tags": [
        "progression",
        "epic"
      ]
    }
  },

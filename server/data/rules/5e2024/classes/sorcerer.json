    "sorcerer-l1-1": {
      "summary": "Awaken a heightened magical state that makes your innate power feel sharper, louder, and more dangerous.",
      "description": "Innate Sorcery is a signature identity button. It tells the player this magic comes from within, and it should read like a heightened casting state rather than a wizard-style study engine.",
      "resourceName": "Innate Sorcery",
      "trackUses": true,
      "tags": [
        "signature",
        "arcane",
        "resource"
      ],
      "section": "Bonus Actions",
      "type": "bonus action",
      "usage": "Activate your heightened sorcerous state when the encounter demands a power spike.",
      "recovery": "Refreshes on a long rest."
    },
    "sorcerer-l1-2": {
      "summary": "Your spells are known instinctively rather than prepared from study, making your list narrower but more personal.",
      "description": "Sorcerer spellcasting should feel intimate and identity-driven. You know fewer tools than a wizard, but the spells you carry should feel like they belong to your bloodline, chaos, or innate magical force.",
      "tags": [
        "spellcasting",
        "arcane",
        "identity"
      ]
    },
    "sorcerer-l2-1": {
      "summary": "You gain Sorcery Points, the core resource that fuels your most flexible class tricks.",
      "description": "Font of Magic is the backbone of the sorcerer. It establishes Sorcery Points as your personal magic economy and should clearly surface your current points, spenders, and recovery assumptions.",
      "resourceName": "Sorcery Points",
      "trackUses": true,
      "tags": [
        "resource",
        "signature",
        "arcane"
      ]
    },
    "sorcerer-l2-2": {
      "summary": "Trade between spell slots and Sorcery Points so your magic adapts to the fight in front of you.",
      "description": "Flexible Casting is what turns Sorcery Points into real decision-making. It lets the sorcerer reshape resources on the fly instead of following a fixed casting pattern.",
      "resourceName": "Sorcery Points",
      "trackUses": true,
      "tags": [
        "resource",
        "conversion",
        "spellcasting"
      ],
      "section": "Class Features",
      "type": "special",
      "usage": "Convert Sorcery Points into spell slots or convert slots into Sorcery Points using Flexible Casting rates.",
      "recovery": "Uses Sorcery Points, which refresh on a long rest."
    },
    "sorcerer-l3-1": {
      "summary": "Your origin explains where your magic comes from and what kind of instability or legacy it carries.",
      "description": "Sorcerous Origin is the subclass gate for sorcerer. It should immediately tell the player whether this power comes from chaos, draconic ancestry, aberrant influence, clockwork structure, or something else.",
      "tags": [
        "subclass",
        "identity",
        "arcane"
      ]
    },
    "sorcerer-l3-2": {
      "summary": "Shape your spells with metamagic so the same spell list can play very differently from one sorcerer to another.",
      "description": "Metamagic is one of the most important sorcerer systems. It should feel like expressive spell customization, not just another passive list entry.",
      "resourceName": "Sorcery Points",
      "trackUses": true,
      "tags": [
        "spellcasting",
        "customization",
        "resource"
      ],
      "section": "Class Features",
      "type": "special",
      "usage": "Choose 2 options at this level. Additional options at levels 10 and 17.",
      "recovery": "Metamagic spends Sorcery Points, which refresh on a long rest.",

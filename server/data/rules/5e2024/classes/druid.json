  "featureDefinitions": {
    "druid-l1-1": {
      "summary": "You learn Druidic, a hidden language used for signs, warnings, and sacred communication across druid circles.",
      "description": "Druidic is a campaign utility language that helps with secret messages, hidden site markers, and faction trust. It is mostly roleplay-facing, but it anchors druid identity from level 1.",
      "tags": [
        "identity",
        "utility",
        "roleplay"
      ]
    },
    "druid-l1-2": {
      "summary": "You are a Wisdom-based prepared full caster using primal magic for healing, control, summons, and terrain influence.",
      "description": "Druid spellcasting uses Wisdom for spell attacks and save DCs. You know cantrips from class progression and prepare leveled spells using Wisdom modifier + druid level. Circle spells (if granted) are extra access and should not be mistaken for Wild Shape resources.",
      "tags": [
        "spellcasting",
        "prepared",
        "wisdom",
        "primal"
      ]
    },
    "druid-l1-3": {
      "summary": "Choose a Primal Order to establish your early play lane: scholar-naturalist depth or sturdier front-line posture.",
      "description": "Primal Order is your first major druid fork. The Scholar/Sage lane emphasizes lore and magical versatility, while the Warden-style lane pushes survivability and front-line readiness. This choice should stay visible in class identity surfaces.",
      "tags": [
        "build",
        "identity",
        "fork"
      ],
      "choices": [
        {
          "id": "primal-order-magician",
          "name": "Magician / Primal Sage",
          "description": "Lean into druid scholarship, magical flexibility, and utility problem-solving."
        },
        {
          "id": "primal-order-warden",
          "name": "Warden / Natural Anchor",
          "description": "Lean into armor, staff-and-shield posture, and front-line durability."
        }
      ]
    },
    "druid-l2-1": {
      "section": "Bonus Actions",
      "type": "bonus action",
      "resourceName": "Wild Shape",
      "trackUses": true,
      "summary": "Spend Wild Shape to assume a beast form for scouting, mobility, utility, or combat pressure depending on your circle.",
      "description": "Wild Shape is a tracked class resource with scaling form limits. It competes with some spellcasting lines early, then cooperates more at high level through Beast Spells and Archdruid. Keep uses, CR limits, and active form state readable in play surfaces.",
      "usage": "Spend 1 Wild Shape use to transform.",
      "recovery": "Short or Long Rest refresh (rules-layer dependent).",
      "tags": [
        "resource",
        "transformation",
        "signature"
      ]
    },
    "druid-l2-2": {
      "section": "Actions",
      "type": "action",
      "resourceName": "Wild Shape",
      "trackUses": true,
      "summary": "Spend a Wild Shape use to summon a temporary familiar-style primal companion for scouting and support utility.",
      "description": "Wild Companion is the non-transform Wild Shape spend option. Use it when battlefield information, touch delivery, or utility support is better than personal transformation.",
      "tags": [
        "resource",
        "summon",
        "utility"
      ],
      "usage": "Spend 1 Wild Shape use to summon your companion.",
      "recovery": "Uses are tied to Wild Shape recovery."
    },
    "druid-l3-1": {
      "summary": "Choose your Druid Circle to define whether your loop centers on battle-shifting, terrain casting, or another future circle identity.",
      "description": "Circle choice is the long-term druid identity gate. Circle of the Moon emphasizes transformation as combat mode, while Circle of the Land emphasizes prepared casting depth, terrain spells, and slot recovery.",
      "tags": [
        "subclass",
        "identity",
        "build"
      ]
    },
    "druid-l18-1": {
      "summary": "Age and ordinary time sit more lightly on you, reinforcing the druid\u2019s connection to a deeper natural cycle.",
      "description": "Timeless Body is not a combat spike. It is an identity spike that marks the druid as someone who has moved into an older, steadier relationship with the natural world.",
      "tags": [
        "passive",
        "identity",
        "capstone-adjacent"
      ]
    },
    "druid-l18-2": {
      "summary": "You can cast many druid spells while in Wild Shape, reducing cast-vs-shift friction.",
      "description": "Beast Spells is the major interaction pivot for druid loops. Before this, shifting often displaces casting; after this, high-level druids can blend form play with meaningful magic output.",
      "tags": [
        "spellcasting",
        "transformation",
        "high-level"
      ]
    },
    "druid-l20-1": {
      "summary": "Your capstone removes Wild Shape scarcity and lets the class loop feel effortless at endgame.",
      "description": "Archdruid is a resource liberation capstone. Wild Shape should feel effectively always available, and the class should read as fully online in both casting and transformation plans.",
      "tags": [
        "capstone",
        "transformation",
        "resource"
      ]
    },
    "druid-druidic": {
      "summary": "You learn Druidic, a hidden language used for signs, warnings, and sacred communication across druid circles.",
      "description": "Druidic is a campaign utility language that helps with secret messages, hidden site markers, and faction trust. It is mostly roleplay-facing, but it anchors druid identity from level 1.",
      "tags": [
        "identity",
        "utility",
        "roleplay"
      ]
    },
    "druid-spellcasting": {
      "summary": "You are a Wisdom-based prepared full caster using primal magic for healing, control, summons, and terrain influence.",
      "description": "Druid spellcasting uses Wisdom for spell attacks and save DCs. You know cantrips from class progression and prepare leveled spells using Wisdom modifier + druid level. Circle spells (if granted) are extra access and should not be mistaken for Wild Shape resources.",
      "tags": [
        "spellcasting",
        "prepared",
        "wisdom",
        "primal"
      ]
    },
    "druid-primal-order": {
      "summary": "Choose a Primal Order to establish your early play lane: scholar-naturalist depth or sturdier front-line posture.",
      "description": "Primal Order is your first major druid fork. The Scholar/Sage lane emphasizes lore and magical versatility, while the Warden-style lane pushes survivability and front-line readiness. This choice should stay visible in class identity surfaces.",
      "tags": [
        "build",
        "identity",
        "fork"
      ],
      "choices": [
        {
          "id": "primal-order-magician",
          "name": "Magician / Primal Sage",
          "description": "Lean into druid scholarship, magical flexibility, and utility problem-solving."
        },
        {
          "id": "primal-order-warden",
          "name": "Warden / Natural Anchor",
          "description": "Lean into armor, staff-and-shield posture, and front-line durability."
        }
      ]
    },

  "featureDefinitions": {
    "druid-l1-1": {
      "summary": "You speak the secret language of druids, marking you as part of an old primal tradition.",
      "description": "Druidic is mostly campaign-facing rather than combat-facing, but it matters for hidden signs, sacred circles, coded warnings, and moments where primal identity should matter in the world.",
      "tags": [
        "identity",
        "utility",
        "roleplay"
      ]
    },
    "druid-l1-2": {
      "summary": "Prepare primal spells that let you heal, control terrain, summon nature, and answer problems with flexible magic.",
      "description": "Druid spellcasting is broad and adaptive. It should feel like a prepared toolkit built around terrain, transformation, healing, battlefield control, and primal problem-solving instead of pure arcane blasting.",
      "tags": [
        "spellcasting",
        "primal",
        "support",
        "control"
      ]
    },
    "druid-l1-3": {
      "summary": "Choose the direction of your druid early so the class leans either toward mystic lore or battlefield durability.",
      "description": "Primal Order is a build-shaping choice. It tells the sheet whether this druid should read more like a front-line natural anchor or a deeper primal scholar, and it should influence the way later features are presented.",
      "tags": [
        "build",
        "identity",
        "primal"
      ]
    },
    "druid-l2-1": {
      "section": "Bonus Actions",
      "type": "bonus action",
      "resourceName": "Wild Shape",
      "trackUses": true,
      "summary": "Spend a Wild Shape use to change form, scout, adapt, or solve problems with beast utility.",
      "description": "Wild Shape is one of the druid’s defining systems. It is not just a combat toggle: it is scouting, infiltration, movement, utility, survival, and sometimes front-line pressure depending on circle. The sheet should make uses, valid forms, and the active form state obvious.",
      "usage": "Spend 1 use of Wild Shape.",
      "recovery": "Wild Shape uses refresh on a Short or Long Rest when supported by the current rules layer.",
      "tags": [
        "resource",
        "transformation",
        "signature",
        "utility"
      ]
    },
    "druid-l2-2": {
      "section": "Actions",
      "type": "action",
      "resourceName": "Wild Shape",
      "trackUses": true,
      "summary": "Trade a Wild Shape use for a familiar-like primal helper that extends your utility and action economy.",
      "description": "Wild Companion gives the druid a softer support use for Wild Shape charges. It matters when scouting, delivering touch effects, or extending your utility without fully changing shape yourself.",
      "tags": [
        "summon",
        "resource",
        "utility"
      ]
    },
    "druid-l3-1": {
      "summary": "Your circle determines whether your druid leans harder into forms, terrain mastery, support, summoning, or another primal identity.",
      "description": "Druid Circle is the subclass gate for druid. It should immediately tell the player how this druid solves problems: shapechanger, land sage, sea mystic, lunar beast, stars seer, and so on.",
      "tags": [
        "subclass",
        "identity",
        "primal"
      ]
    },
    "druid-l18-1": {
      "summary": "Age and ordinary time sit more lightly on you, reinforcing the druid’s connection to a deeper natural cycle.",
      "description": "Timeless Body is not a combat spike. It is an identity spike that marks the druid as someone who has moved into an older, steadier relationship with the natural world.",
      "tags": [
        "passive",
        "identity",
        "capstone-adjacent"
      ]
    },
    "druid-l18-2": {
      "summary": "You can keep using magic while shaped, removing one of the biggest tensions in the druid class fantasy.",
      "description": "Beast Spells is a huge quality jump for shape-based druids because it lets form play and spellcasting cooperate instead of competing. It should feel like the class fantasy finally clicking into place.",
      "tags": [
        "spellcasting",
        "transformation",
        "signature"
      ]
    },
    "druid-l20-1": {
      "summary": "Your primal mastery reaches its peak, making both your forms and spellcasting feel endlessly available.",
      "description": "Archdruid is the final expression of druid identity. It should read like constant readiness: wild shape pressure, spellcasting freedom, and primal control that no longer feels rationed like a low-level adventurer.",
      "tags": [
        "capstone",
        "primal",
        "signature"
      ]
    }
  },

  "featureDefinitions": {
    "pirate-sea-legs": {
      "summary": "Your movement, balance, and footing stay reliable on unstable ground, rigging, and decks.",
      "description": "Sea Legs is the class foundation. A Pirate should feel immediately harder to pin down in messy spaces: gangplanks, ropes, rocking decks, tavern tables, and cluttered battlefields. Even before the class becomes flashy, the player should feel like they belong in motion.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "mobility",
        "exploration",
        "pirate"
      ]
    },
    "pirate-swagger-dice": {
      "summary": "Gain Swagger Dice, a renewable pool of daring that powers tricks, pressure, and leadership.",
      "description": "Swagger Dice are the class resource and social signature. They represent nerve, bravado, timing, and the way a Pirate seizes a room or a fight. The sheet should surface them like a real spendable currency with obvious use buttons later attached to subclass and class tricks.",
      "section": "Class Features",
      "type": "passive",
      "resourceName": "Swagger Dice",
      "trackUses": true,
      "tags": [
        "resource",
        "support",
        "combat"
      ]
    },
    "pirate-dirty-fighting": {
      "summary": "Unlock dirty tricks that reward positioning, distraction, and mean little advantages.",
      "description": "Dirty Fighting is what keeps the Pirate from feeling like a generic rogue-fighter hybrid. The class should encourage opportunistic play: blind the mark, shove them into bad footing, yank them out of position, or set up the crew for a better turn.",
      "section": "Actions",
      "type": "special",
      "tags": [
        "combat",
        "control",
        "tactics"
      ]
    },
    "pirate-cunning-footwork": {
      "summary": "Move through threatened spaces and awkward angles more freely than most warriors.",
      "description": "This feature pushes the class into mobile skirmisher territory. It should read like clean, practical mobility rather than magic, helping the Pirate get to ladders, rails, cover, and flank lanes without the player feeling trapped.",
      "section": "Bonus Actions",
      "type": "bonus action",
      "tags": [
        "mobility",
        "combat"
      ]
    },
    "pirate-boarding-action": {
      "summary": "Explode into a fight with a burst of movement or pressure when you close the distance.",
      "description": "Boarding Action is a tempo feature. When the Pirate commits, the turn should feel dramatic and forward-moving, like a leap over a rail or a rush through smoke into the center of a melee.",
      "section": "Bonus Actions",
      "type": "bonus action",
      "tags": [
        "mobility",
        "burst",
        "combat"
      ]
    },
    "pirate-pirate-calling-subclass": {
      "summary": "Choose the style of Pirate you became: duelist, captain, infiltrator, or terror of the seas.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "subclass",
        "identity"
      ]
    },
    "pirate-marked-quarry": {
      "summary": "Single out a target and pressure them with relentless pursuit and opportunistic punishment.",
      "description": "Marked Quarry gives the Pirate a target-priority engine. It is less about mystical hunting and more about reading the table, calling the shot, and making one enemy feel hunted by timing and presence.",
      "section": "Bonus Actions",
      "type": "bonus action",
      "tags": [
        "combat",
        "focus",
        "control"
      ]
    },
    "pirate-ability-score-improvement-1": {
      "summary": "Increase ability scores or take a feat.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "progression",
        "feat"
      ]
    },
    "pirate-ability-score-improvement-2": {
      "summary": "Increase ability scores or take a feat.",
      "section": "Class Features",

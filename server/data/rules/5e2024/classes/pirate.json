      "tags": [
        "progression",
        "feat"
      ]
    },
    "pirate-extra-attack": {
      "summary": "Attack twice whenever you take the Attack action.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "combat"
      ]
    },
    "pirate-swagger-dice-d8": {
      "summary": "Your Swagger Dice improve to d8s, making your tricks and support sharper.",
      "section": "Class Features",
      "type": "passive",
      "resourceName": "Swagger Dice",
      "trackUses": true,
      "tags": [
        "resource",
        "progression"
      ]
    },
    "pirate-no-quarter": {
      "summary": "Capitalize on fear and disarray when an enemy is already under pressure.",
      "description": "No Quarter gives the class a vicious midgame identity. Once a Pirate has momentum, they should feel excellent at turning hesitation into collapse, especially against wounded, frightened, or cornered foes.",
      "section": "Class Features",
      "type": "special",
      "tags": [
        "combat",
        "pressure"
      ]
    },
    "pirate-uncanny-balance": {
      "summary": "Stay upright, mobile, and dangerous even in terrain that should slow everyone else down.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "mobility",
        "defense"
      ]
    },
    "pirate-menacing-reputation": {
      "summary": "Your name starts affecting scenes before the fight even begins.",
      "description": "This is the class\u2019s social inflection point. A veteran Pirate should not only win on a map; they should bend negotiations, intimidation, and morale by showing up with a reputation that matters.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "social",
        "exploration",
        "presence"
      ]
    },
    "pirate-subclass-feature-10": {
      "summary": "Gain your next major subclass feature.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "subclass",
        "progression"
      ]
    },
    "pirate-press-the-advantage": {
      "summary": "When your crew gains momentum, chain that advantage into extra pressure or support.",
      "description": "This is the feature that makes the Pirate feel like a battlefield opportunist rather than a rotation class. A good turn should create the next good turn, whether that means more damage, a shove, a reposition, or a setup for an ally.",
      "section": "Class Features",
      "type": "special",
      "tags": [
        "combat",
        "support",
        "momentum"
      ]
    },
    "pirate-swagger-dice-d10": {
      "summary": "Your Swagger Dice improve to d10s.",
      "section": "Class Features",
      "type": "passive",
      "resourceName": "Swagger Dice",
      "trackUses": true,
      "tags": [
        "resource",
        "progression"
      ]
    },
    "pirate-master-of-the-boarding-line": {
      "summary": "Own ladders, rails, gangways, and other narrow spaces where movement decides the fight.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "mobility",
        "control",
        "terrain"
      ]
    },
    "pirate-legend-of-the-waves": {
      "summary": "Your sheer confidence and seamanship let you dictate the flow of chaotic battles.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "presence",
        "mobility",
        "high-level"
      ]
    },
    "pirate-subclass-feature-15": {
      "summary": "Gain your capstone subclass feature.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "subclass",
        "capstone"
      ]
    },
    "pirate-dread-volley": {
      "summary": "Unload a decisive flurry of attacks, shots, or thrown weapons when the moment breaks open.",
      "description": "At high level, the Pirate should finally get a legendary burst turn that feels like pistols, blades, thrown steel, and ruthless precision all going off in one cinematic sequence.",
      "section": "Actions",
      "type": "action",
      "resourceName": "Swagger Dice",
      "trackUses": true,
      "tags": [
        "combat",
        "burst",
        "finisher"
      ]
    },
    "pirate-indomitable-swagger": {
      "summary": "Refuse to fold when fear, pain, or bad odds should make lesser fighters break.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "defense",
        "willpower",
        "capstone"
      ]
    },
    "pirate-epic-boon": {
      "summary": "Gain an Epic Boon.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "epic",
        "progression"
      ]
    },
    "pirate-king-of-the-black-flag": {
      "summary": "Become the definitive pirate legend: impossible to ignore, hard to pin down, and deadly once you commit.",
      "description": "King of the Black Flag is the final statement of the class. At this point the Pirate should feel like the center of a boarding scene or sea duel, combining leadership, panic, movement, and brutal opportunism into one finished fantasy.",
      "section": "Class Features",
      "type": "passive",
      "tags": [
        "capstone",
        "legendary",
        "social",
        "combat"
      ]
    }
  },

  "featureDefinitions": {
    "fighter-fighting-style": {
      "summary": "Lock in a permanent combat specialty that tells the player how this fighter prefers to win exchanges.",
      "description": "Fighting Style is one of the clearest identity levers on the fighter chassis. It should be obvious from the sheet whether the character is built around defense, archery, dueling, great weapons, or another weapon plan, because that decision colors almost every later choice.",
      "tags": [
        "combat",
        "build",
        "passive"
      ]
    },
    "fighter-second-wind": {
      "summary": "Catch your breath and restore a meaningful chunk of staying power without surrendering your whole turn.",
      "description": "Second Wind is the fighter\u2019s quick self-stabilizer. It is there so the class can keep operating through chip damage, survive one more exchange, and avoid feeling fragile just because the healer is busy elsewhere.",
      "section": "Bonus Actions",
      "type": "bonus action",
      "resourceName": "Second Wind",
      "trackUses": true,
      "usage": "1 use available",
      "recovery": "Regain all expended uses on a Short or Long Rest.",
      "effect": "Immediate self-healing and a steadier front-line presence.",
      "tags": [
        "healing",
        "resource",
        "combat"
      ]
    },
    "fighter-weapon-mastery": {
      "summary": "Your weapons do more than deal damage \u2014 they carry rider properties that reward choosing the right tool for the job.",
      "description": "Weapon Mastery is one of the features that makes the modern fighter feel technical instead of empty. Different weapons now imply different control, pressure, or positioning lines, so the sheet should make those mastered choices visible and easy to understand.",
      "tags": [
        "combat",
        "weapons",
        "passive"
      ]
    },
    "fighter-action-surge-1-use": {
      "summary": "Explode a turn with an extra action when tempo matters more than patience.",
      "description": "Action Surge is one of the fighter\u2019s signature power spikes. Use it when an extra action changes the whole round: finish a target, reposition and still attack, cast and attack as an Eldritch Knight, or seize the opening before the enemy recovers.",
      "resourceName": "Action Surge",
      "trackUses": true,
      "usage": "1 use available",
      "recovery": "Regain all expended uses on a Short or Long Rest.",
      "effect": "Gain one extra action on your turn.",
      "tags": [
        "combat",
        "burst",
        "resource"
      ]
    },
    "fighter-tactical-mind": {
      "summary": "Turn disciplined focus into better clutch checks when the group needs someone to solve a problem cleanly.",
      "description": "Tactical Mind exists so the fighter contributes outside raw attack math. It is a reminder that this class is not only muscle; it is trained battlefield judgment that can turn an important check from failure into success.",
      "tags": [
        "utility",
        "skills",
        "combat-mindset"
      ]
    },
    "fighter-martial-archetype-subclass": {
      "summary": "Your archetype decides what kind of fighter you really are beyond the base attack engine.",
      "description": "Martial Archetype is the subclass gate for fighter. This is where the class becomes a Battle Master, Champion, Eldritch Knight, or Psi Warrior and starts playing with a distinct tactical identity.\n\nThe sheet should treat this as a major fork because later subclass features are what stop high-level fighters from feeling like only \u201cmore attacks.\u201d",
      "tags": [
        "subclass",
        "combat",
        "identity",
        "build"
      ]
    },
    "fighter-indomitable-1-use": {
      "summary": "Refuse a bad save result when the fight is too important to lose to one failed defense.",
      "description": "Indomitable is the fighter\u2019s answer to swingy saving throws. When a crippling effect would take you out of the scene, this feature gives you another chance to hold the line and keep acting like the martial anchor of the team.",
      "resourceName": "Indomitable",
      "trackUses": true,
      "usage": "1 use available",
      "recovery": "Regain all expended uses on a Long Rest.",
      "tags": [
        "defense",
        "resource",
        "survival"
      ]
    },
    "fighter-tactical-shift": {
      "summary": "Reposition aggressively without completely giving up your turn economy.",
      "description": "Tactical Shift makes the fighter feel more active in real maps and not just in a damage spreadsheet. It is about moving to the square that matters while still keeping offensive pressure online.",
      "tags": [
        "mobility",
        "combat",
        "tempo"
      ]
    },
    "fighter-studied-attacks": {
      "summary": "Longer exchanges reward your experience as you read patterns and convert pressure into more reliable offense.",
      "description": "Studied Attacks is a veteran-fighter feature about momentum. Over repeated rounds, the fighter should feel more certain, more punishing, and harder for enemies to survive through simple repetition.",
      "tags": [
        "combat",
        "tempo",
        "passive"
      ]
    }
  },

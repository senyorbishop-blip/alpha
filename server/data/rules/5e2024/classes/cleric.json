  "featureDefinitions": {
    "cleric-spellcasting": {
      "summary": "Prepare and wield divine magic from the full cleric list using Wisdom as your casting ability.",
      "description": "Cleric spellcasting is the backbone of the class. You prepare spells from the cleric list each day, use Wisdom for your spell attacks and save DC, and pivot between healing, protection, control, and radiant pressure depending on what the party needs.\n\nIn play, this should feel flexible rather than narrow: the same cleric can solve attrition with healing, anchor the front line with buffs, or answer undead and hostile magic with the right prepared list.",
      "tags": [
        "spellcasting",
        "divine",
        "support",
        "control"
      ]
    },
    "cleric-divine-order": {
      "summary": "Choose the side of clerical training you want to emphasize so the class starts with a clearer battlefield and role identity.",
      "description": "Divine Order is the first big fork in how your cleric plays. It decides whether your build leans harder into scholarship, discipline, and sacred study or into a more armored, battle-ready priest style.\n\nThis choice should be visible in the sheet because it affects how the player understands the class from level 1 onward: support caster, battle priest, or a hybrid of both.",
      "tags": [
        "build",
        "divine",
        "identity"
      ]
    },
    "cleric-channel-divinity-1-use": {
      "summary": "Spend Channel Divinity to power major cleric or domain effects when the moment really matters.",
      "description": "Channel Divinity is your premier class resource. It fuels signature cleric buttons such as Divine Spark, Turn Undead, and subclass-specific options like Radiance of the Dawn or Invoke Duplicity.\n\nIn play, this should feel like a high-value tactical choice rather than background text. The player should always understand how many uses remain, which actions consume a use, and whether the current fight is worth spending one now.",
      "resourceName": "Channel Divinity",
      "trackUses": true,
      "section": "Actions",
      "type": "action",
      "usage": "1 use available",
      "recovery": "Regain all expended uses on a Short or Long Rest.",
      "tags": [
        "divine",
        "resource",
        "action"
      ]
    },
    "cleric-divine-spark": {
      "summary": "Release focused divine power to either restore an ally or punish a target with radiant or necrotic force.",
      "description": "Divine Spark is your dependable Channel Divinity option when you need immediate impact. It turns the class resource into direct healing or damage instead of a passive aura or setup effect.\n\nUse it when a single creature needs to swing now: lift an ally, finish a threatening target, or force a visible turn in momentum without spending a spell slot.",
      "section": "Actions",
      "type": "action",
      "resourceName": "Channel Divinity",
      "trackUses": true,
      "effect": "Immediate healing or divine damage with no spell-slot cost.",
      "tags": [
        "divine",
        "healing",
        "damage",
        "resource"
      ]
    },
    "cleric-turn-undead": {
      "summary": "Drive undead back with holy force and break the shape of an encounter that depends on them closing in.",
      "description": "Turn Undead is a battlefield control Channel Divinity, not just lore flavor. Against undead-heavy encounters it can buy space, protect weaker allies, and stop the enemy line from playing the fight it wanted.\n\nThis feature matters most when the cleric reads the room early and spends it before the undead horde has already collapsed onto the party.",
      "section": "Actions",
      "type": "action",
      "resourceName": "Channel Divinity",
      "trackUses": true,
      "save": "Wisdom save",
      "effect": "Undead creatures that fail are repelled and lose tempo.",
      "tags": [
        "divine",
        "control",
        "resource",
        "undead"
      ]
    },
    "cleric-divine-domain-subclass": {
      "summary": "Your chosen domain defines what kind of cleric you really are and which signature powers start shaping the build.",
      "description": "Divine Domain is the subclass gate for cleric. It is where the class stops being a generic divine caster and becomes a Light cleric, Trickery cleric, War cleric, or Life cleric with a distinct play pattern.\n\nFrom this point on, the sheet should surface domain actions, passive riders, and any domain-specific uses of Channel Divinity clearly enough that the subclass feels like a real identity shift.",
      "tags": [
        "subclass",
        "divine",
        "identity",
        "build"
      ]
    },
    "cleric-blessed-strikes": {
      "summary": "Your regular offense gains a reliable divine rider so your turns stay meaningful even when you are not spending top resources.",
      "description": "Blessed Strikes keeps the cleric’s baseline pressure relevant by adding divine payoff to weapon attacks or cantrip damage. It matters because not every turn is a perfect high-level spell turn; sometimes you need dependable value while preserving slots.",
      "tags": [
        "combat",
        "divine",
        "passive"
      ]
    },
    "cleric-divine-intervention": {
      "summary": "Call on your deity for a dramatic answer when the situation is too important for ordinary magic to cover alone.",
      "description": "Divine Intervention is the cleric fantasy spike. It should read like a momentous plea for direct aid rather than a generic spell-like button.\n\nIn play, it belongs in boss fights, desperate rescues, or scenes where the party needs more than efficient math and wants the cleric to ask for something greater than routine casting.",
      "section": "Actions",
      "type": "action",
      "tags": [
        "divine",
        "capstone",
        "miracle"
      ]
    },
    "cleric-greater-divine-intervention": {
      "summary": "Your god answers with far greater certainty, turning Divine Intervention from a gamble into a true endgame class payoff.",
      "description": "Greater Divine Intervention is the high-level reward for a lifetime of service. By this point the cleric should feel like a chosen instrument of divine power, and the sheet should treat this as a major class-defining button rather than a footnote at level 20.",
      "tags": [
        "divine",
        "capstone",
        "miracle",
        "endgame"
      ]
    }
  },

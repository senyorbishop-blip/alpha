{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "casualdnd://rules/5e2024/schema/talent.schema.json",
  "title": "Casual D&D 5e 2024 Talent",
  "description": "Native Casual D&D talent layer kept separate from official class/subclass progression.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "classRestrictions",
    "minimumLevel",
    "grants",
    "tags",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "classRestrictions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "minimumLevel": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "grants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "id": {
            "type": "string"
          },
          "value": {},
          "scope": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedRulesModes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "const": "casualdnd_talent"
    }
  },
  "additionalProperties": true
}

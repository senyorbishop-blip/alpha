# ─────────────────────────────────────────────────────────────────
# D&D Tabletop — Environment Variables
#
# Copy this file to .env and fill in values for your deployment.
# All keys are safe placeholders only — do not commit real secrets.
# ─────────────────────────────────────────────────────────────────

# ── Core security/auth (RECOMMENDED for founder beta) ───────────
# Stable JWT signing secret (set a long random value in production/public use).
DND_JWT_SECRET=

# Admin key for /admin/* operations (password reset + commercial admin paths).
# Sent by admin tools as the X-Admin-Key request header.
DND_ADMIN_KEY=

# ── Runtime data location overrides (optional) ───────────────────
# Default data root is OS-specific (see docs/backup-update-rollback.md).
# Set this if you want data in a custom folder.
DND_DATA_DIR=

# Optional direct DB file override.
DND_DB_PATH=

# ── Narration / TTS providers (all optional) ─────────────────────
# High-quality provider (server-side).
ELEVENLABS_API_KEY=

# Gemini TTS provider.
GEMINI_API_KEY=
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# OpenAI (used for map image generation and optional TTS fallback).
OPENAI_API_KEY=

# Replicate image provider.
REPLICATE_API_TOKEN=
# REPLICATE_MODEL=black-forest-labs/flux-1.1-pro

# Stability image provider (deprecated path; optional).
STABILITY_API_KEY=

# Anthropic key for AI cartographer planning and AI DM helpers.
ANTHROPIC_API_KEY=

# AI DM safety controls.
AI_DM_ENABLED=true
AI_DM_RATE_LIMIT_PER_MINUTE=6
AI_DM_RATE_LIMIT_PER_DAY=100
# Default allows DM and assistant DM only for NPC speech.
AI_DM_NPC_SPEAK_ALLOWED_ROLES=dm,assistant_dm

# Force an image provider (optional): openai | replicate | stability
IMAGE_PROVIDER=

# ── Hosting / Runtime mode ───────────────────────────────────────
# development: local-first defaults
# production: hosted/public-safe defaults
APP_ENV=development

# Public base URL for links/diagnostics behind domains/reverse proxies.
# Example: https://tabletop.example.com
PUBLIC_BASE_URL=

# Legacy/simple compatibility settings.
PUBLIC_DOMAIN=
PORT=8000
NGROK_DOMAIN=

# Trust X-Forwarded-For / X-Forwarded-Proto headers from a reverse proxy.
#
# Set to true ONLY when a trusted proxy (nginx, Caddy, Apache, Traefik, …) sits
# in front of this server and forwards those headers. When true the app uses the
# forwarded IP for auth rate-limiting and logging, and respects the forwarded
# protocol for secure-cookie detection.
#
# Leave false for direct internet exposure — forged X-Forwarded-For headers from
# untrusted clients could spoof any IP and bypass IP-based rate limits.
#
# See docs/hosting-access-guide.md § "TRUST_PROXY_HEADERS" for nginx/Apache/Caddy
# config snippets and an explanation of what breaks when this is wrong.
TRUST_PROXY_HEADERS=false

# ── Cookie + auth rate limits ────────────────────────────────────
AUTH_COOKIE_NAME=dnd_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_DOMAIN=

AUTH_RATE_LIMIT_ENABLED=false
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ── Commercial layer metadata scaffold ───────────────────────────
COMMERCIAL_DEPLOYMENT_MODEL=self_host
COMMERCIAL_DEFAULT_PLAN=community
SUPPORT_CONTACT_EMAIL=
SUPPORT_PORTAL_URL=
LEGAL_TERMS_URL=
LEGAL_PRIVACY_URL=
LEGAL_DPA_URL=
RELEASE_RUNBOOK_VERSION=v1

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
